{
  "name": "@xingwangzhe/bfs-rs",
  "version": "0.1.0",
  "description": "Rust BFS on compressed adjacency list with Rayon parallelism",
  "main": "index.js",
  "types": "index.d.ts",
  "type": "module",
  "license": "MIT",
  "author": "xingwangzhe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xingwangzhe/FriendLinks.git",
    "directory": "native/bfs-rs"
  },
  "keywords": ["bfs", "graph", "rayon", "napi-rs", "rust"],
  "files": [
    "index.d.ts",
    "index.js",
    "bfs-rs.linux-x64-gnu.node"
  ],
  "napi": {
    "binaryName": "bfs-rs",
    "targets": [
      "x86_64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --platform --release"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0",
    "@oxc-node/core": "^0.1.0",
    "ava": "^8.0.0",
    "typescript": "^6.0.0"
  }
}
